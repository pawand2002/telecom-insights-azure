```bash
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.egg
*.egg-info/
dist/
build/
venv/
.env

# Data files (too large for GitHub)
data_generation/output/
*.csv
*.parquet
*.avro

# Credentials — NEVER commit these
*.key
*.pem
secrets.json
config_local.py

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Power BI Desktop files (binary — use screenshots instead)
*.pbix
EOF
```